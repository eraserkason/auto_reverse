# ===== 数据库 =====
DATABASE_URL=mysql+pymysql://auto_reverse:auto_reverse_pwd@127.0.0.1:3306/auto_reverse?charset=utf8mb4
DATABASE_ECHO=false

# ===== 鉴权 =====
JWT_SECRET_KEY=CHANGE_ME_IN_PROD
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=240

# ===== 启动时默认管理员（可选） =====
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123456

# ===== 跨域白名单 =====
# 联调阶段可先全开放（*）；上线前建议改为精确域名列表。
CORS_ALLOW_ORIGINS=*
# 当 CORS_ALLOW_ORIGINS 非 * 时，允许内网网段来源（localhost/127/10/172.16-31/192.168）。
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|10\\.\\d+\\.\\d+\\.\\d+|172\\.(1[6-9]|2\\d|3[0-1])\\.\\d+\\.\\d+|192\\.168\\.\\d+\\.\\d+)(:\\d+)?$

# ===== Agent 相关（保持兼容） =====
LLM_MODEL=gpt-4o
REDIS_URL=redis://localhost:6379
REDIS_SESSION_PREFIX=browser
MCP_SERVERS_CONFIG=./mcp_servers.json
MAX_CONCURRENT_BROWSERS=3
